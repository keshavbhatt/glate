<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.ktechpit.glate</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Glate</name>
  <summary>Translate text and generate speech audio on Linux desktop</summary>

  <developer id="com.ktechpit">
    <name>Keshav Bhatt</name>
  </developer>

  <description>
    <p>Glate is a desktop translator with built-in text to speech for fast daily translation workflows.</p>
    <p>It supports language-to-language translation, per-line translation, speech playback, and exporting translated text or speech output.</p>
    <ul>
      <li>Translate between 100+ languages</li>
      <li>Line-by-line translation view for long content</li>
      <li>Built-in text to speech playback and MP3 export</li>
      <li>History tracking and quick copy/share actions</li>
      <li>Dark and light themes</li>
    </ul>
  </description>

  <launchable type="desktop-id">com.ktechpit.glate.desktop</launchable>
  <icon type="stock">com.ktechpit.glate</icon>

